# ============================================================
# Cardio AI Operations Platform - environment variables
# Copy this file to ".env" for local development.
# On Render.com, add these in the dashboard (Environment tab).
# ============================================================

# --- Core ---
NODE_ENV=development
PORT=3000

# Long random string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Public base URL of the app.
# Local:  http://localhost:3000
# Render: https://cardioai-operations.onrender.com
# (On Render this is auto-detected from RENDER_EXTERNAL_URL if left blank.)
BASE_URL=http://localhost:3000

# --- Database ---
# Postgres connection string. Leave BLANK for local dev (the app falls back to a
# JSON file). On Render this is injected automatically by the Blueprint.
# To use Postgres locally, paste your Render database's EXTERNAL connection
# string here, e.g.:
#   DATABASE_URL=postgresql://user:pass@dpg-xxxx.oregon-postgres.render.com/cardioai_operations
DATABASE_URL=

# --- Google OAuth (from Google Cloud Console) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must EXACTLY match an Authorized redirect URI in Google Console.
# Local:  http://localhost:3000/auth/google/callback
# Render: https://cardioai-operations.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Access control ---
# Only Google accounts on these domains may sign in (comma-separated).
ALLOWED_EMAIL_DOMAIN=cardioailive.com

# Optional: extra individual emails allowed regardless of domain
# (e.g. an outside advisor on a personal account). Comma-separated.
ALLOWED_EMAILS=

# --- Sales Engine integration (live pipeline pull) ---
# Pipeline sources for the Sales Pipeline tab.
# Multi-source (recommended): comma-separated "name=url" entries.
PIPELINE_SOURCES=sales=https://cardioai-sales.onrender.com,crm=https://cardio-ai-crm.onrender.com
# Single-source fallback (back-compat) if PIPELINE_SOURCES is not set:
SALES_ENGINE_URL=https://your-sales-engine.onrender.com
# Optional tuning:
# INTEGRATION_CACHE_MS=60000
# INTEGRATION_TIMEOUT_MS=8000
# Shared secret — must be the SAME value set on the sales engine.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_API_KEY=
